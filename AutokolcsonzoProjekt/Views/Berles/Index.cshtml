@model IEnumerable<AutokolcsonzoProjekt.Models.Berles>

@{
    ViewData["Title"] = "Index";
}

<h1>Bérlések listája</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form asp-action="Index" method="get">
    <p>
        Szűrők:
        <input type="text" name="tav" value="@ViewData["AktualisTavSzuro"]" placeholder="Táv" />
        <input type="date" name="datum" value="@ViewData["AktualisDatumSzuro"]" placeholder="Dátum" />

        <input type="submit" value="Keresés" class="btn btn-primary" />
    </p>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Datum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Tol)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Ig)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Tav)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Auto)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Datum)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Tol)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Ig)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Tav)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Auto.Meghajtas)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.ID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
